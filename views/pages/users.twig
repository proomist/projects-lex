{% extends 'layouts/app.twig' %}

{% block content %}
<div class="bg-white border border-slate-200 rounded-lg shadow-sm flex flex-col h-full min-h-[500px]">
    <!-- Toolbar -->
    <div class="px-5 py-4 border-b border-slate-100 flex flex-wrap items-center justify-between gap-4 shrink-0">
        <div class="flex items-center gap-2">
            <h3 class="font-semibold text-gray-custom flex items-center gap-2">
                <i data-lucide="shield" class="w-5 h-5 text-gold-custom"></i>
                Personel ve Yetkiler
            </h3>
            <span class="bg-slate-100 text-slate-600 text-xs px-2 py-0.5 rounded-full border border-slate-200 font-medium" id="total-count">0 Kayıt</span>
        </div>
        
        <div class="flex items-center gap-3">
            {% if current_user.role in ['Kurucu Ortak', 'Sistem Yöneticisi'] %}
            <button onclick="openUserModal()" class="bg-gray-custom hover:bg-[#333] text-white px-4 py-2 rounded-md text-sm font-medium transition-colors flex items-center gap-2 shadow-sm">
                <i data-lucide="user-plus" class="w-4 h-4 text-gold-custom"></i> Yeni Kullanıcı
            </button>
            {% endif %}
        </div>
    </div>

    <!-- Info Banner for Roles -->
    <div class="bg-blue-50/50 border-b border-blue-100 px-5 py-4 shrink-0">
        <div class="flex items-start gap-3">
            <i data-lucide="info" class="w-5 h-5 text-blue-500 mt-0.5 shrink-0"></i>
            <div class="text-sm text-blue-900 space-y-1">
                <p class="font-medium mb-2 text-blue-950">Sistemdeki Unvan ve Yetki Dağılımı:</p>
                <ul class="list-disc list-inside space-y-1 ml-1 text-blue-800/80">
                    <li><strong class="text-blue-900">Kurucu Ortak / Sistem Yöneticisi:</strong> Tüm sayfalara (Ayarlar, Raporlar, Kullanıcı Yönetimi vb.) tam erişime sahiptir.</li>
                    <li><strong class="text-blue-900">Ortak Avukat:</strong> Ayarlar ve Kullanıcı Yönetimi hariç tüm modüllere (Finans, Raporlar dahil) erişebilir.</li>
                    <li><strong class="text-blue-900">Avukat / Stajyer:</strong> Sadece Dosyalar, Müvekkiller ve Görevleri görebilir; Finans, Raporlar ve Ayarlara erişemez.</li>
                    <li><strong class="text-blue-900">Muhasebeci / Sekreter:</strong> Finansal ekranlara erişebilir ancak sistem ayarlarını yönetemez.</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="flex-1 overflow-auto custom-scroll relative">
        <table class="w-full text-sm text-left">
            <thead class="bg-slate-50 text-slate-500 font-medium sticky top-0 z-10 shadow-sm border-b border-slate-200">
                <tr>
                    <th class="px-5 py-3">Personel Adı</th>
                    <th class="px-5 py-3">E-posta</th>
                    <th class="px-5 py-3">Unvan / Rol</th>
                    <th class="px-5 py-3">Durum</th>
                    <th class="px-5 py-3 text-right">İşlemler</th>
                </tr>
            </thead>
            <tbody id="usersTableBody" class="divide-y divide-slate-100">
                <tr><td colspan="5" class="text-center py-8 text-slate-500">Yükleniyor...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal: Yeni/Düzenle -->
<div id="userModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4 opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg flex flex-col max-h-[90vh] transform scale-95 transition-transform duration-300" id="userModalContent">
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between shrink-0">
            <h3 class="text-lg font-semibold text-gray-custom flex items-center gap-2" id="modalTitle">
                <i data-lucide="user-plus" class="w-5 h-5 text-gold-custom"></i> Yeni Kullanıcı Ekle
            </h3>
            <button onclick="closeUserModal()" class="text-slate-400 hover:text-rose-500 transition-colors p-1 rounded-md hover:bg-rose-50">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <div class="p-6 overflow-y-auto custom-scroll">
            <!-- Uyarı/Hata Mesajı Alanı -->
            <div id="modalAlert" class="hidden mb-4 p-3 rounded-md text-sm font-medium"></div>

            <form id="userForm" class="space-y-5" onsubmit="event.preventDefault(); saveUser();">
                <input type="hidden" id="user_id">
                
                <div class="grid grid-cols-2 gap-5">
                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Ad <span class="text-rose-500">*</span></label>
                        <input type="text" id="first_name" required class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>
                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Soyad <span class="text-rose-500">*</span></label>
                        <input type="text" id="last_name" required class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>

                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Kullanıcı Adı <span class="text-rose-500">*</span></label>
                        <input type="text" id="username" required class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>

                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">E-posta <span class="text-rose-500">*</span></label>
                        <input type="email" id="email" required class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>

                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Şifre <span class="text-xs text-slate-400 font-normal ml-1" id="password_hint">(Zorunlu, en az 8 karakter)</span></label>
                        <input type="password" id="password" oninput="updatePasswordStrength(this.value)" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                        <div id="password_strength" class="mt-2 hidden">
                            <div class="flex gap-1 mb-1">
                                <div id="str_bar_1" class="h-1.5 flex-1 rounded-full bg-slate-200 transition-colors"></div>
                                <div id="str_bar_2" class="h-1.5 flex-1 rounded-full bg-slate-200 transition-colors"></div>
                                <div id="str_bar_3" class="h-1.5 flex-1 rounded-full bg-slate-200 transition-colors"></div>
                                <div id="str_bar_4" class="h-1.5 flex-1 rounded-full bg-slate-200 transition-colors"></div>
                            </div>
                            <p id="str_text" class="text-xs text-slate-500"></p>
                        </div>
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Unvan / Rol <span class="text-rose-500">*</span></label>
                        <select id="title" required class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                        </select>
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Durum</label>
                        <select id="status" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                            <option value="Aktif">Aktif</option>
                            <option value="Askıda">Askıda</option>
                            <option value="Pasif">Pasif</option>
                        </select>
                    </div>
                </div>
            </form>
        </div>
        <div class="px-6 py-4 border-t border-slate-200 flex items-center justify-end gap-3 shrink-0 bg-slate-50 rounded-b-lg">
            <button type="button" onclick="closeUserModal()" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors">İptal</button>
            <button type="button" onclick="saveUser()" id="saveBtn" class="bg-gold-custom hover:bg-[#b89e6e] text-gray-900 px-6 py-2 rounded-md text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                <i data-lucide="save" class="w-4 h-4"></i> <span id="saveBtnText">Kaydet</span>
            </button>
        </div>
    </div>
</div>

{% endblock %}

{% block extra_scripts %}
<script>
    // --- Şifre Güç Göstergesi ---
    function updatePasswordStrength(pw) {
        const container = document.getElementById('password_strength');
        if (!pw || pw.length === 0) {
            container.classList.add('hidden');
            return;
        }
        container.classList.remove('hidden');

        let score = 0;
        if (pw.length >= 6) score++;
        if (pw.length >= 10) score++;
        if (/[a-z]/.test(pw) && /[A-Z]/.test(pw)) score++;
        if (/[0-9]/.test(pw)) score++;
        if (/[^a-zA-Z0-9]/.test(pw)) score++;

        // Normalize to 1-4
        let level = 0;
        if (score <= 1) level = 1;
        else if (score === 2) level = 2;
        else if (score === 3) level = 3;
        else level = 4;

        const colors = ['', 'bg-rose-500', 'bg-amber-500', 'bg-yellow-400', 'bg-emerald-500'];
        const labels = ['', 'Çok Zayıf', 'Zayıf', 'Orta', 'Güçlü'];
        const textColors = ['', 'text-rose-600', 'text-amber-600', 'text-yellow-600', 'text-emerald-600'];

        for (let i = 1; i <= 4; i++) {
            const bar = document.getElementById(`str_bar_${i}`);
            bar.className = `h-1.5 flex-1 rounded-full transition-colors ${i <= level ? colors[level] : 'bg-slate-200'}`;
        }

        const textEl = document.getElementById('str_text');
        textEl.textContent = labels[level];
        textEl.className = `text-xs ${textColors[level]}`;
    }

    // Modal UI
    function openUserModal(id = null) {
        document.getElementById('userForm').reset();
        document.getElementById('user_id').value = '';
        document.getElementById('modalTitle').innerHTML = '<i data-lucide="user-plus" class="w-5 h-5 text-gold-custom"></i> Yeni Kullanıcı Ekle';
        document.getElementById('modalAlert').classList.add('hidden');
        document.getElementById('password_hint').textContent = '(Zorunlu, en az 8 karakter)';
        document.getElementById('password_strength').classList.add('hidden');
        lucide.createIcons();

        if (id) {
            document.getElementById('modalTitle').innerHTML = '<i data-lucide="edit" class="w-5 h-5 text-gold-custom"></i> Kullanıcı Düzenle';
            document.getElementById('password_hint').textContent = '(Sadece değiştirmek istiyorsanız girin, en az 8 karakter)';
            loadUserDetails(id);
        }

        const modal = document.getElementById('userModal');
        const content = document.getElementById('userModalContent');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            content.classList.remove('scale-95');
        }, 10);
    }

    function closeUserModal() {
        const modal = document.getElementById('userModal');
        const content = document.getElementById('userModalContent');
        modal.classList.add('opacity-0');
        content.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }, 300);
    }

    function showAlert(msg, isError = true) {
        const alertEl = document.getElementById('modalAlert');
        alertEl.textContent = msg;
        alertEl.className = `mb-4 p-3 rounded-md text-sm font-medium ${isError ? 'bg-rose-50 text-rose-700 border border-rose-200' : 'bg-emerald-50 text-emerald-700 border border-emerald-200'}`;
        alertEl.classList.remove('hidden');
    }

    // --- API İşlemleri ---

    async function loadUsers() {
        const tbody = document.getElementById('usersTableBody');
        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-8 text-slate-500"><i data-lucide="loader-2" class="w-6 h-6 animate-spin mx-auto mb-2"></i> Yükleniyor...</td></tr>';
        lucide.createIcons();

        const res = await apiCall('/users');
        
        if (!res || res.status !== 'success') {
            tbody.innerHTML = `<tr><td colspan="5" class="text-center py-8 text-rose-500">${res?.message || 'Hata oluştu'}</td></tr>`;
            return;
        }

        const data = res.data;
        document.getElementById('total-count').textContent = `${data.length} Kayıt`;

        if (data.length === 0) {
            tbody.innerHTML = emptyStateRow('shield', 'Kullanıcı Bulunamadı', 'Henüz kullanıcı kaydı oluşturulmamış.', 'Yeni Kullanıcı Ekle', 'openUserModal()', 5);
            createLucideIcons(tbody);
            return;
        }

        const currentUserRole = '{{ current_user.role }}';
        
        tbody.innerHTML = data.map(u => {
            const statusColor = u.status === 'Aktif' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : (u.status === 'Askıda' ? 'bg-amber-50 text-amber-700 border-amber-200' : 'bg-slate-100 text-slate-600 border-slate-200');

            let actionButtons = '';
            if (['Kurucu Ortak', 'Sistem Yöneticisi'].includes(currentUserRole)) {
                actionButtons = `
                    <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                        <button onclick="openUserModal(${u.id})" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded transition-colors" title="Düzenle">
                            <i data-lucide="edit" class="w-4 h-4"></i>
                        </button>
                        ${u.title !== 'Kurucu Ortak' ? `
                        <button onclick="deleteUser(${u.id})" class="p-1.5 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded transition-colors" title="Sil">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>` : ''}
                    </div>
                `;
            }

            return `
                <tr class="hover:bg-slate-50/50 transition-colors group">
                    <td class="px-5 py-3">
                        <div class="font-medium text-slate-800">${u.first_name} ${u.last_name}</div>
                        <div class="text-[10px] text-slate-400">@${u.username}</div>
                    </td>
                    <td class="px-5 py-3 text-slate-600 text-sm">${u.email}</td>
                    <td class="px-5 py-3 text-slate-700 text-sm font-medium">${u.title}</td>
                    <td class="px-5 py-3">
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border ${statusColor}">
                            ${u.status}
                        </span>
                    </td>
                    <td class="px-5 py-3 text-right">
                        ${actionButtons}
                    </td>
                </tr>
            `;
        }).join('');
        
        lucide.createIcons();
    }

    async function loadUserDetails(id) {
        // Liste üzerinde tüm veriler var ama spesifik user için API'den tekrar çekilebilir.
        // Şimdilik listeleme API'sini kullanarak mevcut veriyi bulalım
        const res = await apiCall('/users');
        if (res && res.status === 'success') {
            const user = res.data.find(u => u.id == id);
            if (user) {
                document.getElementById('user_id').value = user.id;
                document.getElementById('first_name').value = user.first_name;
                document.getElementById('last_name').value = user.last_name;
                document.getElementById('username').value = user.username;
                document.getElementById('email').value = user.email;
                await populateSelect('title', 'user_titles', user.title);
                document.getElementById('status').value = user.status;
            }
        }
    }

    async function saveUser() {
        const id = document.getElementById('user_id').value;
        const btn = document.getElementById('saveBtn');
        const btnText = document.getElementById('saveBtnText');

        const payload = {
            first_name: document.getElementById('first_name').value,
            last_name: document.getElementById('last_name').value,
            username: document.getElementById('username').value,
            email: document.getElementById('email').value,
            title: document.getElementById('title').value,
            status: document.getElementById('status').value
        };

        const password = document.getElementById('password').value;
        if (password) {
            if (password.length < 8) {
                return showAlert('Şifre en az 8 karakter olmalıdır.');
            }
            payload.password = password;
        } else if (!id) {
            return showAlert('Yeni kullanıcı eklerken şifre zorunludur.');
        }

        btn.disabled = true;
        btnText.textContent = 'Kaydediliyor...';
        document.getElementById('modalAlert').classList.add('hidden');

        const endpoint = id ? `/users/${id}` : '/users';
        const method = id ? 'PUT' : 'POST';

        const res = await apiCall(endpoint, method, payload);
        
        btn.disabled = false;
        btnText.textContent = 'Kaydet';

        if (!res || res.status !== 'success') {
            showAlert(res?.message || 'Bir hata oluştu.', true);
        } else {
            showAlert('Başarıyla kaydedildi.', false);
            setTimeout(() => {
                closeUserModal();
                loadUsers();
            }, 1000);
        }
    }

    async function deleteUser(id) {
        const confirmed = await showConfirm(
            'Kullanıcıyı Sil',
            'Bu kullanıcıyı silmek istediğinize emin misiniz?',
            'Evet, Sil'
        );
        if (!confirmed) return;
        
        const res = await apiCall(`/users/${id}`, 'DELETE');
        if (!res || res.status !== 'success') {
            showToast('Hata: ' + (res?.message || 'Silinemedi.'), 'error');
        } else {
            loadUsers();
        }
    }

    document.addEventListener('DOMContentLoaded', async () => {
        await populateSelect('title', 'user_titles');
        loadUsers();
    });
</script>
{% endblock %}
