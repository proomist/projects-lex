{% extends 'layouts/app.twig' %}

{% block content %}
<div class="bg-white border border-slate-200 rounded-lg shadow-sm flex flex-col h-full min-h-[500px]">
    <!-- Toolbar -->
    <div class="px-5 py-4 border-b border-slate-100 flex flex-wrap items-center justify-between gap-4 shrink-0">
        <div class="flex items-center gap-2">
            <h3 class="font-semibold text-gray-custom flex items-center gap-2">
                <i data-lucide="settings" class="w-5 h-5 text-gold-custom"></i>
                Sistem Ayarları
            </h3>
        </div>

        <button type="button" onclick="saveSettings()" class="bg-gray-custom hover:bg-[#333] text-white px-4 py-2 rounded-md text-sm font-medium transition-colors flex items-center gap-2 shadow-sm">
            <i data-lucide="save" class="w-4 h-4 text-gold-custom"></i> Kaydet
        </button>
    </div>

    <!-- Content -->
    <div class="flex-1 overflow-auto custom-scroll relative p-5">
        <form id="settingsForm" class="max-w-4xl space-y-8" onsubmit="event.preventDefault();">

            <!-- Genel Bilgiler -->
            <div>
                <h4 class="text-sm font-semibold text-gray-custom border-b border-slate-200 pb-2 mb-4 flex items-center gap-2">
                    <i data-lucide="building" class="w-4 h-4 text-slate-400"></i> Genel Bilgiler
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Uygulama Adı <span class="text-rose-500">*</span></label>
                        <input type="text" name="app_name" id="app_name" required class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Büro / Şirket Adı <span class="text-rose-500">*</span></label>
                        <input type="text" name="company_name" id="company_name" required class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>
                </div>
            </div>

            <!-- Kurumsal ve İletişim -->
            <div>
                <h4 class="text-sm font-semibold text-gray-custom border-b border-slate-200 pb-2 mb-4 flex items-center gap-2">
                    <i data-lucide="contact" class="w-4 h-4 text-slate-400"></i> Kurumsal ve İletişim
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Vergi Dairesi</label>
                        <input type="text" name="tax_office" id="tax_office" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Vergi Numarası</label>
                        <input type="text" name="tax_number" id="tax_number" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Telefon</label>
                        <input type="tel" name="phone" id="phone" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">E-posta</label>
                        <input type="email" name="email" id="email" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Adres</label>
                        <textarea name="address" id="address" rows="3" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all"></textarea>
                    </div>
                </div>
            </div>

            <!-- Sistem Tercihleri -->
            <div>
                <h4 class="text-sm font-semibold text-gray-custom border-b border-slate-200 pb-2 mb-4 flex items-center gap-2">
                    <i data-lucide="sliders-horizontal" class="w-4 h-4 text-slate-400"></i> Sistem Tercihleri
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Varsayılan Para Birimi</label>
                        <select name="currency" id="currency" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all bg-white">
                            <option value="TRY">Türk Lirası (₺)</option>
                            <option value="USD">Amerikan Doları ($)</option>
                            <option value="EUR">Euro (€)</option>
                            <option value="GBP">İngiliz Sterlini (£)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Zaman Dilimi</label>
                        <select name="timezone" id="timezone" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all bg-white">
                            <option value="Europe/Istanbul">Avrupa / İstanbul (UTC+3)</option>
                            <option value="Europe/London">Avrupa / Londra (UTC+0)</option>
                            <option value="America/New_York">Amerika / New York (UTC-5)</option>
                        </select>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block extra_scripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        loadSettings();
    });

    async function loadSettings() {
        try {
            const response = await apiCall('/settings', 'GET');
            if (response && response.status === 'success' && response.data) {
                const data = response.data;
                document.getElementById('app_name').value = data.app_name || '';
                document.getElementById('company_name').value = data.company_name || '';
                document.getElementById('tax_office').value = data.tax_office || '';
                document.getElementById('tax_number').value = data.tax_number || '';
                document.getElementById('phone').value = data.phone || '';
                document.getElementById('email').value = data.email || '';
                document.getElementById('address').value = data.address || '';
                document.getElementById('currency').value = data.currency || 'TRY';
                document.getElementById('timezone').value = data.timezone || 'Europe/Istanbul';
            }
        } catch (error) {
            console.error('Ayarlar yüklenemedi:', error);
        }
    }

    async function saveSettings() {
        const form = document.getElementById('settingsForm');

        if (!form.reportValidity()) {
            return;
        }

        const data = {
            app_name: document.getElementById('app_name').value.trim(),
            company_name: document.getElementById('company_name').value.trim(),
            tax_office: document.getElementById('tax_office').value.trim(),
            tax_number: document.getElementById('tax_number').value.trim(),
            phone: document.getElementById('phone').value.trim(),
            email: document.getElementById('email').value.trim(),
            address: document.getElementById('address').value.trim(),
            currency: document.getElementById('currency').value,
            timezone: document.getElementById('timezone').value
        };

        try {
            const response = await apiCall('/settings', 'PUT', data);

            if (response && response.status === 'success') {
                showToast('Ayarlar başarıyla kaydedildi.', 'success');
            } else {
                showToast(response?.message || 'Bir hata oluştu.', 'error');
            }
        } catch (error) {
            console.error('Ayarlar kaydedilemedi:', error);
            showToast('Ayarlar kaydedilirken sunucu ile iletişim kurulamadı.', 'error');
        }
    }
</script>
{% endblock %}
