<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ error_code }} — {{ error_title }}</title>
    <link rel="icon" type="image/png" href="/assets/proomist-favicon-01.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'gold-custom': '#cfb481',
                        'gray-custom': '#282828',
                    }
                }
            }
        }
    </script>
    <script src="https://unpkg.com/lucide@0.344.0"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'IBM Plex Sans', sans-serif; }
        @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-10px); } }
        .float-anim { animation: float 3s ease-in-out infinite; }
    </style>
</head>
<body class="h-screen flex flex-col bg-[#f4f4f5] antialiased selection:bg-gold-custom/20 selection:text-gray-900">

    <!-- Header -->
    <header class="h-12 bg-gray-custom text-white flex items-center justify-between px-4 shrink-0 shadow-md z-30 border-b border-[#3c3c3c]">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded bg-gold-custom/20 flex items-center justify-center border border-gold-custom/30">
                <i data-lucide="scale" class="w-5 h-5 text-gold-custom"></i>
            </div>
            <span class="font-semibold tracking-wide text-white">Proomist LEX</span>
        </div>
    </header>

    <!-- Content -->
    <main class="flex-1 flex items-center justify-center p-6">
        <div class="max-w-lg w-full text-center">

            <!-- Icon -->
            <div class="float-anim mb-6 inline-flex items-center justify-center w-24 h-24 rounded-2xl {{ icon_bg }}">
                <i data-lucide="{{ icon }}" class="w-12 h-12 {{ icon_color }}"></i>
            </div>

            <!-- Error Code -->
            <h1 class="text-7xl font-bold text-gray-custom/20 mb-2 select-none">{{ error_code }}</h1>

            <!-- Title -->
            <h2 class="text-xl font-bold text-gray-custom mb-3">{{ error_title }}</h2>

            <!-- Message -->
            <p class="text-sm text-slate-500 mb-8 max-w-md mx-auto leading-relaxed">{{ error_message }}</p>

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
                <a href="/dashboard" class="inline-flex items-center gap-2 bg-gray-custom hover:bg-[#333] text-white px-5 py-2.5 rounded-lg font-medium text-sm transition-colors shadow-sm">
                    <i data-lucide="home" class="w-4 h-4 text-gold-custom"></i>
                    Ana Sayfaya D&ouml;n
                </a>
                <button onclick="history.back()" class="inline-flex items-center gap-2 bg-white hover:bg-slate-50 text-slate-700 px-5 py-2.5 rounded-lg font-medium text-sm transition-colors border border-slate-200 shadow-sm">
                    <i data-lucide="arrow-left" class="w-4 h-4 text-slate-400"></i>
                    Geri Git
                </button>
            </div>

            {% if detail %}
            <!-- Dev Detail (only in development) -->
            <div class="mt-8 text-left bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden">
                <div class="px-4 py-2.5 bg-slate-50 border-b border-slate-200 flex items-center gap-2">
                    <i data-lucide="bug" class="w-4 h-4 text-slate-400"></i>
                    <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Geli&scedil;tirici Detay&inodot;</span>
                </div>
                <div class="p-4 text-xs font-mono text-slate-600 space-y-1.5 overflow-x-auto">
                    <div><span class="text-slate-400">Type:</span> {{ detail.type }}</div>
                    <div><span class="text-slate-400">Message:</span> {{ detail.message }}</div>
                    <div><span class="text-slate-400">File:</span> {{ detail.file }}:{{ detail.line }}</div>
                </div>
            </div>
            {% endif %}
        </div>
    </main>

    <!-- Footer -->
    <footer class="h-7 bg-[#282828] border-t border-[#3c3c3c] flex items-center justify-center px-3 shrink-0 text-[11px] text-gray-400 font-medium z-20 select-none">
        <span class="flex items-center gap-1">
            <i data-lucide="shield-check" class="w-3.5 h-3.5 text-emerald-500"></i> Proomist LEX
        </span>
    </footer>

    <script>lucide.createIcons();</script>
</body>
</html>
