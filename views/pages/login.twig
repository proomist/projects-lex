{% extends 'layouts/auth.twig' %}

{% block title %}Giriş Yap{% endblock %}

{% block content %}
    <div class="relative z-10 w-full max-w-md p-8">
        
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gold-custom/10 border border-gold-custom/20 mb-4 shadow-lg">
                <i data-lucide="scale" class="w-8 h-8 text-gold-custom"></i>
            </div>
            <h1 class="text-3xl font-bold text-white tracking-tight mb-2">Proomist Hukuk</h1>
            <p class="text-gold-custom/80 text-sm">Hukuk Ofisi Yönetim Sistemi</p>
        </div>

        <div class="bg-[#333] border border-[#444] rounded-2xl p-8 shadow-2xl">
            
            <div id="loginAlert" class="hidden mb-6 p-3 rounded-md text-sm font-medium text-center border"></div>

            <form id="loginForm" class="space-y-5" onsubmit="event.preventDefault(); doLogin();">
                <div>
                    <label class="block text-sm font-medium text-gray-400 mb-1.5">E-posta Adresi</label>
                    <div class="relative">
                        <i data-lucide="mail" class="w-5 h-5 text-gray-500 absolute left-3 top-1/2 -translate-y-1/2"></i>
                        <input type="email" id="email" required placeholder="ornek@hukuk.com" 
                            class="w-full bg-[#222] border border-[#444] text-white rounded-xl pl-10 pr-4 py-3 text-sm transition-all focus:border-gold-custom placeholder-gray-600">
                    </div>
                </div>

                <div>
                    <div class="flex items-center justify-between mb-1.5">
                        <label class="block text-sm font-medium text-gray-400">Şifre</label>
                    </div>
                    <div class="relative">
                        <i data-lucide="lock" class="w-5 h-5 text-gray-500 absolute left-3 top-1/2 -translate-y-1/2"></i>
                        <input type="password" id="password" required placeholder="••••••••" 
                            class="w-full bg-[#222] border border-[#444] text-white rounded-xl pl-10 pr-4 py-3 text-sm transition-all focus:border-gold-custom placeholder-gray-600">
                    </div>
                </div>

                <button type="submit" id="loginBtn" class="w-full mt-6 bg-gold-custom hover:bg-[#b89e6e] text-gray-900 font-bold py-3 px-4 rounded-xl transition-all shadow-lg shadow-gold-custom/20 flex items-center justify-center gap-2">
                    <span>Giriş Yap</span>
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </button>
            </form>
        </div>

        <p class="text-center text-gray-500 text-xs mt-8">
            &copy; 2026 Proomist Governance Consulting
        </p>

    </div>
{% endblock %}

{% block extra_scripts %}
    <script>
        // Login sayfasına gelindi → eski UI cache'ini temizle
        // (Cookie süresi dolmuş veya logout yapılmış olabilir)
        localStorage.removeItem('legal_user');

        async function doLogin() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const btn = document.getElementById('loginBtn');
            const alertEl = document.getElementById('loginAlert');

            alertEl.classList.add('hidden');
            btn.disabled = true;
            btn.innerHTML = '<i data-lucide="loader-2" class="w-5 h-5 animate-spin"></i> Giriş Yapılıyor...';
            lucide.createIcons();

            try {
                const response = await fetch('/api/v1/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: email, password: password }),
                    credentials: 'include' // Cookie'nin kaydedilmesi için gerekli
                });

                const data = await response.json();

                if (response.ok && data.status === 'success') {
                    // Sadece UI bilgisi için – güvenlik token'ı cookie'de (HttpOnly)
                    localStorage.setItem('legal_user', JSON.stringify(data.data.user));
                    
                    alertEl.textContent = 'Giriş başarılı, yönlendiriliyorsunuz...';
                    alertEl.className = 'mb-6 p-3 rounded-md text-sm font-medium text-center border bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
                    alertEl.classList.remove('hidden');

                    setTimeout(() => {
                        window.location.href = '/dashboard';
                    }, 800);

                } else {
                    btn.disabled = false;
                    btn.innerHTML = '<span>Giriş Yap</span><i data-lucide="arrow-right" class="w-4 h-4"></i>';
                    lucide.createIcons();

                    alertEl.textContent = data.message || 'Giriş başarısız.';
                    alertEl.className = 'mb-6 p-3 rounded-md text-sm font-medium text-center border bg-rose-500/10 text-rose-400 border-rose-500/20';
                    alertEl.classList.remove('hidden');
                }

            } catch (error) {
                btn.disabled = false;
                btn.innerHTML = '<span>Giriş Yap</span><i data-lucide="arrow-right" class="w-4 h-4"></i>';
                lucide.createIcons();

                alertEl.textContent = 'Sunucu bağlantı hatası.';
                alertEl.className = 'mb-6 p-3 rounded-md text-sm font-medium text-center border bg-rose-500/10 text-rose-400 border-rose-500/20';
                alertEl.classList.remove('hidden');
            }
        }
    </script>
{% endblock %}
