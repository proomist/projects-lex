{% extends 'layouts/app.twig' %}

{% block content %}
<div class="bg-white border border-slate-200 rounded-lg shadow-sm flex flex-col h-full min-h-[500px]">
    <!-- Toolbar -->
    <div class="px-5 py-4 border-b border-slate-100 flex flex-wrap items-center justify-between gap-4 shrink-0">
        <div class="flex items-center gap-2">
            <h3 class="font-semibold text-gray-custom flex items-center gap-2">
                <i data-lucide="wallet" class="w-5 h-5 text-gold-custom"></i>
                Mali Takip
            </h3>
            <span class="bg-slate-100 text-slate-600 text-xs px-2 py-0.5 rounded-full border border-slate-200 font-medium" id="total-count">0 Kayıt</span>
        </div>

        <div class="flex items-center gap-3 flex-wrap">
            <select id="typeFilter" class="border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom" onchange="currentPage=1; loadFinance()">
                <option value="">Tümü</option>
                <option value="Alacak">Alacak</option>
                <option value="Tahsilat">Tahsilat (Tümü)</option>
                <option value="Tahsilat|ucret">Ücret Tahsilatı</option>
                <option value="Tahsilat|emanet">Emanet</option>
                <option value="Gider">Gider (Tümü)</option>
                <option value="Gider|masraf">Müvekkil Masrafı</option>
                <option value="Gider|genel">Büro Gideri</option>
            </select>
            <div class="flex items-center gap-1">
                <input type="date" id="dateFrom" class="border border-slate-300 rounded-md px-2 py-2 text-sm outline-none focus:border-gold-custom w-[140px]" onchange="currentPage=1; loadFinance()" title="Başlangıç Tarihi">
                <span class="text-slate-400 text-xs">-</span>
                <input type="date" id="dateTo" class="border border-slate-300 rounded-md px-2 py-2 text-sm outline-none focus:border-gold-custom w-[140px]" onchange="currentPage=1; loadFinance()" title="Bitiş Tarihi">
                <button onclick="clearDateFilters()" class="p-2 text-slate-400 hover:text-rose-500 transition-colors rounded-md hover:bg-rose-50" title="Tarih Filtresini Temizle">
                    <i data-lucide="x-circle" class="w-4 h-4"></i>
                </button>
            </div>
            <button onclick="openFinanceModal()" class="bg-gray-custom hover:bg-[#333] text-white px-4 py-2 rounded-md text-sm font-medium transition-colors flex items-center gap-2 shadow-sm">
                <i data-lucide="plus" class="w-4 h-4 text-gold-custom"></i> Yeni İşlem
            </button>
        </div>
    </div>

    <!-- Table -->
    <div class="flex-1 overflow-auto custom-scroll relative">
        <table class="w-full text-sm text-left">
            <thead class="bg-slate-50 text-slate-500 font-medium sticky top-0 z-10 shadow-sm border-b border-slate-200">
                <tr>
                    <th class="px-5 py-3">Tarih</th>
                    <th class="px-5 py-3">Tip / Kategori</th>
                    <th class="px-5 py-3">İlgili Kişi / Dosya</th>
                    <th class="px-5 py-3">Açıklama</th>
                    <th class="px-5 py-3 text-right">Tutar</th>
                    <th class="px-5 py-3">Durum</th>
                    <th class="px-5 py-3 text-right">İşlemler</th>
                </tr>
            </thead>
            <tbody id="financeTableBody" class="divide-y divide-slate-100">
                <tr><td colspan="7" class="text-center py-8 text-slate-500">Yükleniyor...</td></tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="px-5 py-3 border-t border-slate-200 bg-slate-50 flex items-center justify-between shrink-0 rounded-b-lg">
        <span class="text-sm text-slate-500" id="page-info">Sayfa 1 / 1</span>
        <div class="flex gap-1">
            <button id="prevPage" onclick="changePage(-1)" class="px-3 py-1 border border-slate-300 rounded bg-white text-slate-600 hover:bg-slate-50 disabled:opacity-50 transition-colors">Önceki</button>
            <button id="nextPage" onclick="changePage(1)" class="px-3 py-1 border border-slate-300 rounded bg-white text-slate-600 hover:bg-slate-50 disabled:opacity-50 transition-colors">Sonraki</button>
        </div>
    </div>
</div>

<!-- Modal: Yeni/Düzenle -->
<div id="financeModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4 opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl flex flex-col max-h-[90vh] transform scale-95 transition-transform duration-300" id="financeModalContent">
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between shrink-0">
            <h3 class="text-lg font-semibold text-gray-custom flex items-center gap-2" id="modalTitle">
                <i data-lucide="wallet" class="w-5 h-5 text-gold-custom"></i> Yeni Mali Kayıt
            </h3>
            <button onclick="closeFinanceModal()" class="text-slate-400 hover:text-rose-500 transition-colors p-1 rounded-md hover:bg-rose-50">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <div class="p-6 overflow-y-auto custom-scroll">
            <div id="modalAlert" class="hidden mb-4 p-3 rounded-md text-sm font-medium"></div>

            <form id="financeForm" class="space-y-5" onsubmit="event.preventDefault(); saveFinance();">
                <input type="hidden" id="transaction_id">

                <div class="grid grid-cols-2 gap-5">

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">İşlem Tipi <span class="text-rose-500">*</span></label>
                        <select id="transaction_type" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all bg-white" onchange="toggleTypeSpecifics()">
                            <option value="Alacak">Alacak (Gelir Beklentisi)</option>
                            <option value="Tahsilat">Tahsilat (Gelen Para)</option>
                            <option value="Gider">Gider (Borç/Masraf)</option>
                        </select>
                    </div>

                    <!-- Alt Tip Seçimi (Tahsilat ve Gider için) -->
                    <div class="col-span-1" id="subTypeContainer">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Alt Tip <span class="text-rose-500">*</span></label>
                        <select id="sub_type" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all bg-white" onchange="toggleSubTypeSpecifics()">
                        </select>
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Kategori <span class="text-rose-500">*</span></label>
                        <select id="category" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all bg-white">
                            <option value="" disabled selected>Seçiniz...</option>
                        </select>
                    </div>

                    <div class="col-span-1" id="clientContainer">
                        <label class="block text-sm font-medium text-slate-700 mb-1">İlgili Müvekkil <span class="text-rose-500" id="clientRequired">*</span></label>
                        <select id="client_id" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all bg-white" onchange="loadCasesForClient()">
                            <option value="">Seçiniz...</option>
                        </select>
                    </div>

                    <div class="col-span-1" id="caseContainer">
                        <label class="block text-sm font-medium text-slate-700 mb-1">İlgili Dosya (Opsiyonel)</label>
                        <select id="case_id" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all bg-white disabled:opacity-50" disabled>
                            <option value="">Önce Müvekkil Seçiniz</option>
                        </select>
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Tutar <span class="text-rose-500">*</span></label>
                        <div class="relative">
                            <i data-lucide="turkish-lira" class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2"></i>
                            <input type="number" id="amount" step="0.01" min="0" class="pl-9 pr-4 py-2 w-full border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all" oninput="updateKdvPreview()">
                        </div>
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">KDV Oranı (%)</label>
                        <input type="number" id="tax_rate" value="20" step="1" min="0" max="100" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all" oninput="updateKdvPreview()">
                    </div>

                    <!-- KDV Hesaplama Yöntemi -->
                    <div class="col-span-2">
                        <div class="flex items-center gap-1 bg-slate-100 rounded-md p-0.5 border border-slate-200 w-fit">
                            <button type="button" id="kdvExclBtn" onclick="setKdvMode('exclusive')"
                                class="px-3 py-1.5 rounded text-xs font-semibold transition-all bg-white text-gray-custom shadow-sm border border-slate-200">
                                KDV Hariç
                            </button>
                            <button type="button" id="kdvInclBtn" onclick="setKdvMode('inclusive')"
                                class="px-3 py-1.5 rounded text-xs font-semibold transition-all text-slate-500 hover:text-slate-700">
                                KDV Dahil
                            </button>
                        </div>
                        <p class="text-[11px] text-slate-400 mt-1" id="kdvModeHint">Girilen tutar KDV hariç net tutardır, KDV üzerine eklenecektir.</p>
                    </div>

                    <!-- KDV Hesaplama Önizleme -->
                    <div id="kdvPreview" class="col-span-2 hidden">
                        <div class="bg-slate-50 border border-slate-200 rounded-md p-3 flex items-center justify-between text-sm">
                            <div class="text-center">
                                <div class="text-slate-500 text-xs mb-0.5">Net Tutar</div>
                                <div class="font-semibold text-slate-700" id="kdvNet">0,00 ₺</div>
                            </div>
                            <div class="text-slate-300">+</div>
                            <div class="text-center">
                                <div class="text-slate-500 text-xs mb-0.5">KDV</div>
                                <div class="font-semibold text-amber-600" id="kdvAmount">0,00 ₺</div>
                            </div>
                            <div class="text-slate-300">=</div>
                            <div class="text-center">
                                <div class="text-slate-500 text-xs mb-0.5">Toplam</div>
                                <div class="font-bold text-emerald-700" id="kdvTotal">0,00 ₺</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">İşlem Tarihi <span class="text-rose-500">*</span></label>
                        <input type="date" id="transaction_date" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>

                    <div class="col-span-1" id="dueDateContainer">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Vade Tarihi</label>
                        <input type="date" id="due_date" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                    </div>

                    <div class="col-span-2" id="statusContainer">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Durum</label>
                        <select id="status" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all bg-white">
                            <option value="Bekliyor">Bekliyor</option>
                            <option value="Vadesi Geldi">Vadesi Geldi</option>
                            <option value="Kısmi Ödendi">Kısmi Ödendi</option>
                            <option value="Ödendi">Ödendi / Tamamlandı</option>
                            <option value="İptal">İptal</option>
                        </select>
                    </div>

                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Açıklama</label>
                        <textarea id="description" rows="2" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all"></textarea>
                    </div>

                </div>
            </form>
        </div>
        <div class="px-6 py-4 border-t border-slate-200 flex items-center justify-end gap-3 shrink-0 bg-slate-50 rounded-b-lg">
            <button type="button" onclick="closeFinanceModal()" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors">İptal</button>
            <button type="button" onclick="saveFinance()" id="saveBtn" class="bg-gold-custom hover:bg-[#b89e6e] text-gray-900 px-6 py-2 rounded-md text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                <i data-lucide="save" class="w-4 h-4"></i> <span id="saveBtnText">Kaydet</span>
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_scripts %}
<script>
    let currentPage = 1;
    const limit = 15;
    let totalPages = 1;
    let clientsCache = [];
    let casesCache = [];

    // Sub-type Türkçe etiketleri
    const subTypeLabels = {
        'ucret': 'Ücret Tahsilatı',
        'emanet': 'Emanet',
        'masraf': 'Müvekkil Masrafı',
        'genel': 'Büro Gideri'
    };

    // Tarih filtreleri
    function clearDateFilters() {
        document.getElementById('dateFrom').value = '';
        document.getElementById('dateTo').value = '';
        currentPage = 1;
        loadFinance();
    }

    // KDV Hesaplama Modu
    let kdvMode = 'inclusive';

    function setKdvMode(mode) {
        kdvMode = mode;
        const exclBtn = document.getElementById('kdvExclBtn');
        const inclBtn = document.getElementById('kdvInclBtn');
        const hint = document.getElementById('kdvModeHint');

        if (mode === 'exclusive') {
            exclBtn.className = 'px-3 py-1.5 rounded text-xs font-semibold transition-all bg-white text-gray-custom shadow-sm border border-slate-200';
            inclBtn.className = 'px-3 py-1.5 rounded text-xs font-semibold transition-all text-slate-500 hover:text-slate-700';
            hint.textContent = 'Girilen tutar KDV hariç net tutardır, KDV üzerine eklenecektir.';
        } else {
            inclBtn.className = 'px-3 py-1.5 rounded text-xs font-semibold transition-all bg-white text-gray-custom shadow-sm border border-slate-200';
            exclBtn.className = 'px-3 py-1.5 rounded text-xs font-semibold transition-all text-slate-500 hover:text-slate-700';
            hint.textContent = 'Girilen tutar KDV dahil brüt tutardır, KDV içinden ayrıştırılacaktır.';
        }
        updateKdvPreview();
    }

    function calculateKdv(inputAmount, taxRate) {
        if (kdvMode === 'inclusive' && taxRate > 0) {
            const total = inputAmount;
            const net = total / (1 + taxRate / 100);
            const tax = total - net;
            return { net: Math.round(net * 100) / 100, tax: Math.round(tax * 100) / 100, total: Math.round(total * 100) / 100 };
        } else {
            const net = inputAmount;
            const tax = Math.round(net * (taxRate / 100) * 100) / 100;
            const total = Math.round((net + tax) * 100) / 100;
            return { net, tax, total };
        }
    }

    function updateKdvPreview() {
        const inputAmount = parseFloat(document.getElementById('amount').value) || 0;
        const taxRate = parseFloat(document.getElementById('tax_rate').value) || 0;
        const preview = document.getElementById('kdvPreview');

        if (inputAmount > 0) {
            const calc = calculateKdv(inputAmount, taxRate);
            const fmt = (v) => new Intl.NumberFormat('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v) + ' \u20BA';
            document.getElementById('kdvNet').textContent = fmt(calc.net);
            document.getElementById('kdvAmount').textContent = fmt(calc.tax);
            document.getElementById('kdvTotal').textContent = fmt(calc.total);
            preview.classList.remove('hidden');
        } else {
            preview.classList.add('hidden');
        }
    }

    let categoryLookupValues = [];

    // Alt tip dropdown yönetimi
    function updateSubTypeOptions() {
        const type = document.getElementById('transaction_type').value;
        const subTypeSelect = document.getElementById('sub_type');
        const subTypeContainer = document.getElementById('subTypeContainer');

        if (type === 'Tahsilat') {
            subTypeContainer.classList.remove('hidden');
            subTypeSelect.innerHTML = '<option value="ucret">Ücret Tahsilatı</option><option value="emanet">Emanet (Avans)</option>';
        } else if (type === 'Gider') {
            subTypeContainer.classList.remove('hidden');
            subTypeSelect.innerHTML = '<option value="masraf">Müvekkil Masrafı</option><option value="genel">Büro Gideri</option>';
        } else {
            subTypeContainer.classList.add('hidden');
            subTypeSelect.innerHTML = '';
        }
    }

    // Büro gideri seçildiğinde müvekkil/dosya alanlarını gizle
    function toggleSubTypeSpecifics() {
        const type = document.getElementById('transaction_type').value;
        const subType = document.getElementById('sub_type').value;
        const clientContainer = document.getElementById('clientContainer');
        const caseContainer = document.getElementById('caseContainer');
        const clientRequired = document.getElementById('clientRequired');

        if (type === 'Gider' && subType === 'genel') {
            clientContainer.classList.add('hidden');
            caseContainer.classList.add('hidden');
            clientRequired.textContent = '';
        } else {
            clientContainer.classList.remove('hidden');
            caseContainer.classList.remove('hidden');
            clientRequired.textContent = '*';
        }
    }

    function toggleTypeSpecifics() {
        const type = document.getElementById('transaction_type').value;
        const dueDateContainer = document.getElementById('dueDateContainer');
        const statusContainer = document.getElementById('statusContainer');

        if (type === 'Alacak') {
            dueDateContainer.classList.remove('hidden');
            statusContainer.classList.remove('hidden');
        } else {
            dueDateContainer.classList.add('hidden');
            statusContainer.classList.add('hidden');
        }

        updateSubTypeOptions();
        toggleSubTypeSpecifics();
    }

    function openFinanceModal(id = null) {
        document.getElementById('financeForm').reset();
        document.getElementById('transaction_id').value = '';
        document.getElementById('modalTitle').innerHTML = '<i data-lucide="wallet" class="w-5 h-5 text-gold-custom"></i> Yeni Mali Kayıt';
        document.getElementById('modalAlert').classList.add('hidden');
        document.getElementById('case_id').disabled = true;
        document.getElementById('case_id').innerHTML = '<option value="">Önce Müvekkil Seçiniz</option>';

        populateSelect('category', 'financial_categories');

        setKdvMode('inclusive');
        document.getElementById('kdvPreview').classList.add('hidden');

        document.getElementById('transaction_date').value = new Date().toISOString().split('T')[0];
        toggleTypeSpecifics();
        lucide.createIcons();

        if (id) {
            document.getElementById('modalTitle').innerHTML = '<i data-lucide="edit" class="w-5 h-5 text-gold-custom"></i> Kayıt Düzenle';
            loadFinanceDetails(id);
        }

        const modal = document.getElementById('financeModal');
        const content = document.getElementById('financeModalContent');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            content.classList.remove('scale-95');
        }, 10);
    }

    function closeFinanceModal() {
        const modal = document.getElementById('financeModal');
        const content = document.getElementById('financeModalContent');
        modal.classList.add('opacity-0');
        content.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }, 300);
    }

    function showAlert(msg, isError = true) {
        const alertEl = document.getElementById('modalAlert');
        alertEl.textContent = msg;
        alertEl.className = `mb-4 p-3 rounded-md text-sm font-medium ${isError ? 'bg-rose-50 text-rose-700 border border-rose-200' : 'bg-emerald-50 text-emerald-700 border border-emerald-200'}`;
        alertEl.classList.remove('hidden');
    }

    async function loadDropdowns() {
        if (clientsCache.length === 0) {
            const res = await apiCall('/clients?limit=1000');
            if (res && res.status === 'success') {
                clientsCache = res.data;
                const select = document.getElementById('client_id');
                select.innerHTML = '<option value="">Seçiniz...</option>';
                clientsCache.forEach(c => {
                    const name = c.client_type === 'Bireysel' ? `${c.first_name} ${c.last_name}` : c.company_name;
                    select.innerHTML += `<option value="${c.id}">${escapeHtml(name)}</option>`;
                });
            }
        }
        if (categoryLookupValues.length === 0) {
            categoryLookupValues = await populateSelect('category', 'financial_categories');
        }
    }

    async function loadCasesForClient() {
        const clientId = document.getElementById('client_id').value;
        const caseSelect = document.getElementById('case_id');

        if (!clientId) {
            caseSelect.innerHTML = '<option value="">Önce Müvekkil Seçiniz</option>';
            caseSelect.disabled = true;
            return;
        }

        caseSelect.disabled = false;
        caseSelect.innerHTML = '<option value="">Yükleniyor...</option>';

        const res = await apiCall(`/cases?limit=1000`);
        if (res && res.status === 'success') {
            const clientCases = res.data.filter(c => c.client_id == clientId);
            caseSelect.innerHTML = '<option value="">Genel Kayıt (Dosya Bağımsız)</option>';
            clientCases.forEach(c => {
                caseSelect.innerHTML += `<option value="${c.id}">${escapeHtml(c.case_no)}</option>`;
            });
        }
    }

    async function loadFinance() {
        const filterVal = document.getElementById('typeFilter').value;
        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;
        const tbody = document.getElementById('financeTableBody');

        tbody.innerHTML = '<tr><td colspan="7" class="text-center py-8 text-slate-500"><i data-lucide="loader-2" class="w-6 h-6 animate-spin mx-auto mb-2"></i> Yükleniyor...</td></tr>';
        lucide.createIcons();

        let query = `?page=${currentPage}&limit=${limit}`;

        // Filtre: "Tahsilat|ucret" formatını parse et
        if (filterVal) {
            const parts = filterVal.split('|');
            query += `&type=${encodeURIComponent(parts[0])}`;
            if (parts[1]) {
                query += `&sub_type=${encodeURIComponent(parts[1])}`;
            }
        }
        if (dateFrom) query += `&date_from=${encodeURIComponent(dateFrom)}`;
        if (dateTo) query += `&date_to=${encodeURIComponent(dateTo)}`;

        const res = await apiCall('/financials' + query);

        if (!res || res.status !== 'success') {
            tbody.innerHTML = `<tr><td colspan="7" class="text-center py-8 text-rose-500">${res?.message || 'Hata oluştu'}</td></tr>`;
            return;
        }

        let data = res.data;
        document.getElementById('total-count').textContent = `${res.meta.total_records} Kayıt`;
        document.getElementById('page-info').textContent = `Sayfa ${res.meta.current_page} / ${res.meta.total_pages || 1}`;
        totalPages = res.meta.total_pages || 1;

        document.getElementById('prevPage').disabled = currentPage <= 1;
        document.getElementById('nextPage').disabled = currentPage >= totalPages;

        if (data.length === 0) {
            tbody.innerHTML = emptyStateRow('wallet', 'Mali Kayıt Bulunamadı', 'Henüz mali kayıt oluşturulmamış veya filtrelere uygun sonuç yok.', 'Yeni İşlem Ekle', 'openFinanceModal()', 7);
            createLucideIcons(tbody);
            return;
        }

        tbody.innerHTML = data.map(f => {
            let typeColor = 'text-slate-600';
            let amountPrefix = '';
            let subLabel = '';

            if (f.transaction_type === 'Tahsilat') {
                typeColor = 'text-emerald-600';
                amountPrefix = '+';
                subLabel = f.sub_type === 'emanet' ? 'Emanet' : 'Ücret';
            } else if (f.transaction_type === 'Gider') {
                typeColor = 'text-rose-600';
                amountPrefix = '-';
                subLabel = f.sub_type === 'genel' ? 'Büro Gideri' : 'Masraf';
            } else if (f.transaction_type === 'Alacak') {
                typeColor = 'text-blue-600';
            }

            let statusColor = 'bg-slate-100 text-slate-600 border-slate-200';
            if (f.status === 'Ödendi') statusColor = 'bg-emerald-50 text-emerald-700 border-emerald-200';
            else if (f.status === 'Kısmi Ödendi') statusColor = 'bg-blue-50 text-blue-700 border-blue-200';
            else if (f.status === 'Gecikti') statusColor = 'bg-rose-50 text-rose-700 border-rose-200';

            let clientName = '';
            if (f.transaction_type === 'Gider' && f.sub_type === 'genel') {
                clientName = 'Büro Gideri';
            } else {
                clientName = f.client_type === 'Bireysel' ? `${f.first_name || ''} ${f.last_name || ''}` : (f.company_name || '');
            }

            const amountFormatted = new Intl.NumberFormat('tr-TR', { style: 'currency', currency: f.currency || 'TRY' }).format(f.total_amount);

            return `
                <tr class="hover:bg-slate-50/50 transition-colors group">
                    <td class="px-5 py-3 text-slate-700 font-medium">${escapeHtml(f.transaction_date)}</td>
                    <td class="px-5 py-3">
                        <div class="font-medium ${typeColor}">${escapeHtml(f.transaction_type)}${subLabel ? ' <span class="text-[10px] font-normal opacity-70">\u00b7 ' + subLabel + '</span>' : ''}</div>
                        <div class="text-[10px] text-slate-500 uppercase mt-0.5">${escapeHtml(f.category)}</div>
                    </td>
                    <td class="px-5 py-3">
                        <div class="text-sm text-slate-800">${escapeHtml(clientName)}</div>
                        <div class="text-xs text-slate-500">Dosya: ${escapeHtml(f.case_no || '-')}</div>
                    </td>
                    <td class="px-5 py-3 text-sm text-slate-600 truncate max-w-[200px]" title="${escapeHtml(f.description || '')}">${escapeHtml(f.description || '-')}</td>
                    <td class="px-5 py-3 text-right font-bold ${typeColor}">${amountPrefix}${amountFormatted}</td>
                    <td class="px-5 py-3">
                        ${f.transaction_type === 'Alacak' && f.status ? `<span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium border ${statusColor}">${f.status}</span>` : '-'}
                    </td>
                    <td class="px-5 py-3 text-right">
                        <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button onclick="openFinanceModal(${f.id})" class="p-1.5 text-slate-400 hover:text-gold-custom hover:bg-gold-custom/10 rounded transition-colors" title="Düzenle">
                                <i data-lucide="edit" class="w-4 h-4"></i>
                            </button>
                            <button onclick="deleteFinance(${f.id})" class="p-1.5 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded transition-colors" title="İptal Et / Sil">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        }).join('');

        lucide.createIcons();
    }

    function changePage(delta) {
        const newPage = currentPage + delta;
        if (newPage >= 1 && newPage <= totalPages) {
            currentPage = newPage;
            loadFinance();
        }
    }

    async function loadFinanceDetails(id) {
        const res = await apiCall(`/financials/${id}`);
        if (!res || res.status !== 'success') {
            showAlert('Kayıt bilgileri alınamadı.');
            return;
        }

        const f = res.data;
        document.getElementById('transaction_id').value = f.id;
        document.getElementById('transaction_type').value = f.transaction_type;

        // Önce tip spesifik alanları güncelle
        toggleTypeSpecifics();

        // Sub-type set et
        if (f.sub_type) {
            document.getElementById('sub_type').value = f.sub_type;
            toggleSubTypeSpecifics();
        }

        const catSelect = document.getElementById('category');
        const catVal = f.category || '';
        if (catVal) {
            const exists = Array.from(catSelect.options).some(o => o.value === catVal);
            if (!exists) {
                const customOpt = document.createElement('option');
                customOpt.value = catVal;
                customOpt.textContent = catVal + ' (Özel)';
                catSelect.appendChild(customOpt);
            }
            catSelect.value = catVal;
        }

        document.getElementById('amount').value = f.amount || '';
        document.getElementById('tax_rate').value = f.tax_rate || '0';
        if (f.transaction_date) document.getElementById('transaction_date').value = f.transaction_date;
        if (f.due_date) document.getElementById('due_date').value = f.due_date;
        document.getElementById('description').value = f.description || '';
        if (f.status) document.getElementById('status').value = f.status;

        updateKdvPreview();

        if (f.client_id) {
            document.getElementById('client_id').value = f.client_id;
            await loadCasesForClient();
            if (f.case_id) {
                document.getElementById('case_id').value = f.case_id;
            }
        }
    }

    async function saveFinance() {
        const id = document.getElementById('transaction_id').value;
        const btn = document.getElementById('saveBtn');
        const btnText = document.getElementById('saveBtnText');

        const type = document.getElementById('transaction_type').value;
        const subTypeEl = document.getElementById('sub_type');
        const subType = subTypeEl.value || null;
        const category = document.getElementById('category').value;
        const clientId = document.getElementById('client_id').value;
        const amount = document.getElementById('amount').value;
        const transDate = document.getElementById('transaction_date').value;

        const isBuroGideri = (type === 'Gider' && subType === 'genel');

        if (!category) return showAlert('Kategori zorunludur.');
        if (!isBuroGideri && !clientId) return showAlert('Müvekkil seçimi zorunludur.');
        if (!amount || amount <= 0) return showAlert('Geçerli bir tutar giriniz.');
        if (!transDate) return showAlert('İşlem tarihi zorunludur.');

        const inputAmount = parseFloat(amount);
        const taxRate = parseFloat(document.getElementById('tax_rate').value || 0);
        const calc = calculateKdv(inputAmount, taxRate);

        const payload = {
            transaction_type: type,
            category: category,
            amount: calc.net,
            tax_rate: taxRate,
            transaction_date: transDate,
            description: document.getElementById('description').value
        };

        // Sub-type ekle (Alacak hariç)
        if (type !== 'Alacak' && subType) {
            payload.sub_type = subType;
        }

        // Büro gideri değilse müvekkil ekle
        if (!isBuroGideri) {
            payload.client_id = parseInt(clientId);
            if (document.getElementById('case_id').value) {
                payload.case_id = parseInt(document.getElementById('case_id').value);
            }
        }

        if (type === 'Alacak') {
            payload.due_date = document.getElementById('due_date').value || null;
            payload.status = document.getElementById('status').value;
        }

        btn.disabled = true;
        btnText.textContent = 'Kaydediliyor...';
        document.getElementById('modalAlert').classList.add('hidden');

        const endpoint = id ? `/financials/${id}` : '/financials';
        const method = id ? 'PUT' : 'POST';

        const res = await apiCall(endpoint, method, payload);

        btn.disabled = false;
        btnText.textContent = 'Kaydet';

        if (!res || res.status !== 'success') {
            showAlert(res?.message || 'Bir hata oluştu.', true);
        } else {
            showAlert('Başarıyla kaydedildi.', false);
            setTimeout(() => {
                closeFinanceModal();
                loadFinance();
            }, 1000);
        }
    }

    async function deleteFinance(id) {
        const confirmed = await showConfirm(
            'İşlemi İptal Et/Sil',
            'Bu kaydı iptal etmek veya silmek istediğinize emin misiniz?',
            'Evet, Sil'
        );
        if (!confirmed) return;

        const res = await apiCall(`/financials/${id}`, 'DELETE');
        if (!res || res.status !== 'success') {
            showToast('Hata: ' + (res?.message || 'İşlem başarısız.'), 'error');
        } else {
            loadFinance();
        }
    }

    document.addEventListener('DOMContentLoaded', async () => {
        await loadDropdowns();
        loadFinance();
    });
</script>
{% endblock %}
