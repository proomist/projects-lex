{% extends "layouts/app.twig" %}

{% block content %}
<div class="bg-white border border-slate-200 rounded-lg shadow-sm flex flex-col h-full min-h-[500px]">
    <!-- Toolbar -->
    <div class="px-5 py-4 border-b border-slate-100 flex flex-wrap items-center justify-between gap-4 shrink-0">
        <div class="flex items-center gap-2">
            <h3 class="font-semibold text-gray-custom flex items-center gap-2">
                <i data-lucide="file-text" class="w-5 h-5 text-gold-custom"></i>
                İşlem Logları
            </h3>
            <span class="bg-slate-100 text-slate-600 text-xs px-2 py-0.5 rounded-full border border-slate-200 font-medium" id="total-count">0 Kayıt</span>
        </div>
        
        <div class="flex items-center gap-3">
            <input type="text" id="filterActor" placeholder="Kullanıcı ara..." 
                class="border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom"
                onkeyup="if(event.key === 'Enter') applyFilters()">
                
            <select id="filterModule" class="border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom" onchange="applyFilters()">
                <option value="">Tümü (Modül)</option>
                <option value="Auth">Kimlik Doğrulama</option>
                <option value="ClientManagement">Müvekkil Yönetimi</option>
                <option value="CaseManagement">Dosya/Dava Yönetimi</option>
                <option value="TaskManagement">Görev Yönetimi</option>
                <option value="Finance">Mali Takip</option>
                <option value="UserManagement">Kullanıcı Yönetimi</option>
                <option value="Settings">Ayarlar</option>
                <option value="Dashboard">Dashboard</option>
            </select>

            <input type="date" id="filterDateFrom" class="border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom" onchange="applyFilters()" title="Başlangıç Tarihi">
            <input type="date" id="filterDateTo" class="border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom" onchange="applyFilters()" title="Bitiş Tarihi">

            <button onclick="clearFilters()" class="text-slate-500 hover:text-slate-700 px-2 py-2 rounded-md text-sm font-medium transition-colors flex items-center gap-1" title="Filtreleri Temizle">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
    </div>

    <!-- Table -->
    <div class="flex-1 overflow-auto custom-scroll relative">
        <table class="w-full text-sm text-left">
            <thead class="bg-slate-50 text-slate-500 font-medium sticky top-0 z-10 shadow-sm border-b border-slate-200">
                <tr>
                    <th class="px-5 py-3">Tarih/Saat</th>
                    <th class="px-5 py-3">Kullanıcı</th>
                    <th class="px-5 py-3">Unvan</th>
                    <th class="px-5 py-3">İşlem</th>
                    <th class="px-5 py-3">Modül</th>
                    <th class="px-5 py-3">IP Adresi</th>
                </tr>
            </thead>
            <tbody id="logsTableBody" class="divide-y divide-slate-100">
                <tr>
                    <td colspan="6" class="px-5 py-8 text-center text-slate-400">
                        <i data-lucide="loader" class="w-6 h-6 inline animate-spin text-gold-custom"></i>
                        <span class="ml-2">Yükleniyor...</span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="px-5 py-3 border-t border-slate-100 bg-slate-50 flex items-center justify-between shrink-0" id="paginationContainer">
        <!-- Pagination injected here -->
    </div>
</div>

<script>
let currentPage = 1;
let currentFilters = {};

async function loadLogs(page = 1) {
    currentPage = page;
    const params = new URLSearchParams({
        page: page.toString(),
        limit: '20',
        ...currentFilters
    });

    try {
        const result = await apiCall('/activity-logs?' + params.toString());

        if (result && result.status === 'success') {
            document.getElementById('total-count').innerText = `${result.meta.total_records} Kayıt`;
            renderLogs(result.data);
            renderPagination(result.meta);
        } else {
            showError('Loglar yüklenirken hata oluştu.');
        }
    } catch (error) {
        console.error('Log yükleme hatası:', error);
        showError('Loglar yüklenirken hata oluştu.');
    }
}

function renderLogs(logs) {
    const tbody = document.getElementById('logsTableBody');
    
    if (logs.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="6" class="px-5 py-8 text-center text-slate-500">
                    <i data-lucide="inbox" class="w-10 h-10 mx-auto mb-2 text-slate-400"></i>
                    <p>Kayıt bulunamadı</p>
                </td>
            </tr>
        `;
        lucide.createIcons();
        return;
    }

    tbody.innerHTML = logs.map(log => {
        const date = new Date(log.created_at);
        const formattedDate = date.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric' });
        const formattedTime = date.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
        
        const actionLabel = getActionLabel(log.action_type);
        const moduleLabel = getModuleLabel(log.module);
        
        return `
            <tr class="hover:bg-slate-50/50 transition-colors group">
                <td class="px-5 py-3">
                    <div class="font-medium text-slate-700">${formattedDate}</div>
                    <div class="text-xs text-slate-500">${formattedTime}</div>
                </td>
                <td class="px-5 py-3">
                    <div class="font-medium text-slate-900">${escapeHtml(log.actor_full_name || 'Bilinmiyor')}</div>
                    <div class="text-xs text-slate-500">${escapeHtml(log.actor_username || '-')}</div>
                </td>
                <td class="px-5 py-3">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-800 border border-slate-200">
                        ${escapeHtml(log.actor_title || '-')}
                    </span>
                </td>
                <td class="px-5 py-3 text-slate-700">${escapeHtml(actionLabel)}</td>
                <td class="px-5 py-3 text-slate-600">${escapeHtml(moduleLabel)}</td>
                <td class="px-5 py-3 font-mono text-xs text-slate-500">${escapeHtml(log.ip_address || '-')}</td>
            </tr>
        `;
    }).join('');
    
    lucide.createIcons();
}

function renderPagination(meta) {
    const container = document.getElementById('paginationContainer');
    
    if (meta.total_pages <= 1) {
        container.innerHTML = `
            <span class="text-sm text-slate-500">Toplam ${meta.total_records} kayıt</span>
        `;
        return;
    }

    const pages = [];
    const maxVisible = 5;
    let startPage = Math.max(1, meta.current_page - Math.floor(maxVisible / 2));
    let endPage = Math.min(meta.total_pages, startPage + maxVisible - 1);

    if (endPage - startPage < maxVisible - 1) {
        startPage = Math.max(1, endPage - maxVisible + 1);
    }

    for (let i = startPage; i <= endPage; i++) {
        pages.push(i);
    }

    container.innerHTML = `
        <span class="text-sm text-slate-500">
            Toplam <span class="font-medium text-slate-700">${meta.total_records}</span> kayıt
        </span>
        <div class="flex gap-1">
            ${meta.current_page > 1 ? `
                <button onclick="loadLogs(${meta.current_page - 1})" 
                    class="px-2.5 py-1.5 bg-white border border-slate-200 text-slate-600 rounded hover:bg-slate-50">
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                </button>
            ` : ''}
            
            ${pages.map(p => `
                <button onclick="loadLogs(${p})" 
                    class="px-3 py-1.5 rounded border ${p === meta.current_page ? 'bg-gold-custom/10 border-gold-custom/30 text-gold-custom font-medium' : 'bg-white border-slate-200 text-slate-600 hover:bg-slate-50'}">
                    ${p}
                </button>
            `).join('')}
            
            ${meta.current_page < meta.total_pages ? `
                <button onclick="loadLogs(${meta.current_page + 1})" 
                    class="px-2.5 py-1.5 bg-white border border-slate-200 text-slate-600 rounded hover:bg-slate-50">
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </button>
            ` : ''}
        </div>
    `;
    
    lucide.createIcons();
}

function applyFilters() {
    currentFilters = {};
    
    const actor = document.getElementById('filterActor').value.trim();
    const module = document.getElementById('filterModule').value;
    const dateFrom = document.getElementById('filterDateFrom').value;
    const dateTo = document.getElementById('filterDateTo').value;
    
    if (actor) currentFilters.actor = actor;
    if (module) currentFilters.module = module;
    if (dateFrom) currentFilters.date_from = dateFrom;
    if (dateTo) currentFilters.date_to = dateTo;
    
    loadLogs(1);
}

function clearFilters() {
    document.getElementById('filterActor').value = '';
    document.getElementById('filterModule').value = '';
    document.getElementById('filterDateFrom').value = '';
    document.getElementById('filterDateTo').value = '';
    currentFilters = {};
    loadLogs(1);
}

function getActionLabel(actionType) {
    const labels = {
        'login_success': 'Başarılı Giriş',
        'login_failed_user_not_found': 'Başarısız Giriş (Kullanıcı Bulunmadı)',
        'login_failed_wrong_password': 'Başarısız Giriş (Hatalı Şifre)',
        'client_created': 'Müvekkil Eklendi',
        'client_updated': 'Müvekkil Güncellendi',
        'client_deleted': 'Müvekkil Silindi',
        'case_created': 'Dosya Eklendi',
        'case_updated': 'Dosya Güncellendi',
        'case_deleted': 'Dosya Silindi',
        'hearing_created': 'Duruşma Eklendi',
        'hearing_updated': 'Duruşma Güncellendi',
        'hearing_deleted': 'Duruşma Silindi',
        'task_created': 'Görev Eklendi',
        'task_updated': 'Görev Güncellendi',
        'task_deleted': 'Görev Silindi',
        'task_checklist_toggled': 'Görev Adımı İşaretlendi',
        'financial_transaction_created': 'Finans Kaydı Eklendi',
        'financial_transaction_updated': 'Finans Kaydı Güncellendi',
        'financial_transaction_deleted': 'Finans Kaydı Silindi',
        'user_created': 'Kullanıcı Eklendi',
        'user_updated': 'Kullanıcı Güncellendi',
        'user_deleted': 'Kullanıcı Silindi',
        'settings_updated': 'Ayarlar Güncellendi',
        'dashboard_viewed': 'Dashboard Görüntülendi'
    };
    return labels[actionType] || actionType;
}

function getModuleLabel(module) {
    const labels = {
        'Auth': 'Sistem Girişi',
        'ClientManagement': 'Müvekkil Ynt.',
        'CaseManagement': 'Dosya/Dava Ynt.',
        'TaskManagement': 'Görev Ynt.',
        'Finance': 'Mali Takip',
        'UserManagement': 'Kullanıcı Ynt.',
        'Settings': 'Ayarlar',
        'Dashboard': 'Ana Ekran'
    };
    return labels[module] || module;
}

function showError(message) {
    const tbody = document.getElementById('logsTableBody');
    tbody.innerHTML = `
        <tr>
            <td colspan="6" class="px-5 py-8 text-center text-red-500">
                <i data-lucide="alert-circle" class="w-8 h-8 mx-auto mb-2 opacity-80"></i>
                <p>${message}</p>
            </td>
        </tr>
    `;
    lucide.createIcons();
}

document.addEventListener('DOMContentLoaded', () => {
    loadLogs(1);
});
</script>
{% endblock %}
