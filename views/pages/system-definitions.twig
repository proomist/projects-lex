{% extends 'layouts/app.twig' %}

{% block content %}
<div class="bg-white border border-slate-200 rounded-lg shadow-sm flex flex-col h-full min-h-[500px]">
    <!-- Toolbar -->
    <div class="px-5 py-4 border-b border-slate-100 flex flex-wrap items-center justify-between gap-4 shrink-0">
        <div class="flex items-center gap-2">
            <h3 class="font-semibold text-gray-custom flex items-center gap-2">
                <i data-lucide="list-ordered" class="w-5 h-5 text-gold-custom"></i>
                Sistem Tanımları
            </h3>
        </div>
    </div>

    <!-- Content: Split Panel -->
    <div class="flex-1 flex flex-col lg:flex-row min-h-0 overflow-hidden">

        <!-- Sol: Grup Listesi -->
        <div class="w-full lg:w-60 shrink-0 border-b lg:border-b-0 lg:border-r border-slate-200 overflow-auto custom-scroll">
            <div class="px-4 py-3 border-b border-slate-100 bg-slate-50 sticky top-0 z-10">
                <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Tanım Grupları</h4>
            </div>
            <div id="groupList" class="divide-y divide-slate-100">
                <div class="text-center py-6 text-slate-400 text-sm">
                    <i data-lucide="loader-2" class="w-5 h-5 animate-spin mx-auto mb-2"></i> Yükleniyor...
                </div>
            </div>
        </div>

        <!-- Sağ: Değerler Paneli -->
        <div class="flex-1 min-w-0 flex flex-col overflow-hidden">
            <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between gap-4 shrink-0 bg-slate-50/50">
                <h4 id="groupTitle" class="font-semibold text-gray-custom truncate text-sm">Bir grup seçin</h4>
                <button id="addBtn" onclick="openAddModal()" class="bg-gray-custom hover:bg-[#333] text-white px-3 py-1.5 rounded-md text-xs font-medium transition-colors items-center gap-1.5 shadow-sm whitespace-nowrap" style="display:none;">
                    <i data-lucide="plus" class="w-3.5 h-3.5 text-gold-custom"></i> Yeni Ekle
                </button>
            </div>
            <div id="valuesContainer" class="flex-1 overflow-auto custom-scroll p-5">
                <div class="flex flex-col items-center py-12 text-slate-400">
                    <i data-lucide="mouse-pointer-click" class="w-10 h-10 mb-3 text-slate-300"></i>
                    <p class="text-sm">Sol panelden bir tanım grubu seçin</p>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Add/Edit Modal -->
<div id="lookupModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4 opacity-0 transition-opacity duration-300">
    <div id="lookupModalContent" class="bg-white rounded-lg shadow-xl w-full max-w-md transform scale-95 transition-transform duration-300">
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between shrink-0">
            <h3 id="lookupModalTitle" class="text-lg font-semibold text-gray-custom flex items-center gap-2">
                <i data-lucide="list-ordered" class="w-5 h-5 text-gold-custom"></i> Yeni Değer Ekle
            </h3>
            <button onclick="closeLookupModal()" class="text-slate-400 hover:text-rose-500 transition-colors p-1 rounded-md hover:bg-rose-50">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <div class="p-6 space-y-4">
            <div id="lookupModalAlert" class="hidden"></div>
            <input type="hidden" id="lookupEditId">
            <div id="lookupValueField">
                <label class="block text-sm font-medium text-slate-700 mb-1">Değer (Kayıt Adı) <span class="text-rose-500">*</span></label>
                <input type="text" id="lookupValue" maxlength="100" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all" placeholder="Örn: Avukat">
                <p class="text-xs text-slate-400 mt-1">Veritabanında kaydedilen değer</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Etiket (Görünen Ad) <span class="text-rose-500">*</span></label>
                <input type="text" id="lookupLabel" maxlength="100" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all" placeholder="Örn: Avukat">
                <p class="text-xs text-slate-400 mt-1">Kullanıcıya gösterilen metin</p>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Sıra</label>
                    <input type="number" id="lookupSortOrder" min="0" value="0" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Durum</label>
                    <select id="lookupIsActive" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm outline-none focus:border-gold-custom focus:ring-1 focus:ring-gold-custom transition-all bg-white">
                        <option value="1">Aktif</option>
                        <option value="0">Pasif</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="px-6 py-4 border-t border-slate-200 flex items-center justify-end gap-3 shrink-0 bg-slate-50 rounded-b-lg">
            <button onclick="closeLookupModal()" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors">İptal</button>
            <button onclick="saveLookup()" class="bg-gold-custom hover:bg-[#b89e6e] text-gray-900 px-6 py-2 rounded-md text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                <i data-lucide="save" class="w-4 h-4"></i>
                <span id="lookupSaveText">Kaydet</span>
            </button>
        </div>
    </div>
</div>

{% endblock %}

{% block extra_scripts %}
<script>
    const groupLabels = {
        'user_titles': 'Personel Ünvanları',
        'case_types': 'Dosya Türleri',
        'client_positions': 'Müvekkil Pozisyonları',
        'closing_types': 'Kapanış Türleri',
        'hearing_types': 'Duruşma Türleri',
        'payment_methods': 'Ödeme Yöntemleri',
        'contact_types': 'İletişim Türleri',
        'task_priorities': 'Görev Öncelikleri',
        'document_types': 'Evrak Türleri',
        'financial_categories': 'Mali Kategoriler'
    };

    const groupIcons = {
        'user_titles': 'user',
        'case_types': 'folder',
        'client_positions': 'users',
        'closing_types': 'check-circle',
        'hearing_types': 'gavel',
        'payment_methods': 'credit-card',
        'contact_types': 'phone',
        'task_priorities': 'flag',
        'document_types': 'file-text',
        'financial_categories': 'wallet'
    };

    let currentGroup = null;
    let currentValues = [];

    document.addEventListener('DOMContentLoaded', () => {
        loadGroups();
    });

    async function loadGroups() {
        try {
            const response = await apiCall('/lookups', 'GET');
            if (response && response.status === 'success') {
                renderGroupList(response.data);
            }
        } catch (e) {
            console.error('Gruplar yüklenemedi:', e);
        }
    }

    function renderGroupList(groups) {
        const container = document.getElementById('groupList');
        const order = Object.keys(groupLabels);
        const sorted = order.filter(key => groups.some(g => g.group_key === key));
        groups.forEach(g => {
            if (!order.includes(g.group_key)) sorted.push(g.group_key);
        });

        let html = '';
        sorted.forEach(key => {
            const group = groups.find(g => g.group_key === key);
            const count = group ? group.count : 0;
            const label = groupLabels[key] || key;
            const icon = groupIcons[key] || 'list';
            const isActive = currentGroup === key;

            html += `
                <button onclick="selectGroup('${escapeHtml(key)}')" class="w-full flex items-center gap-3 px-4 py-2.5 text-left transition-colors ${isActive ? 'bg-gold-custom/10 text-gold-custom border-r-2 border-gold-custom' : 'text-slate-600 hover:bg-slate-50'}">
                    <i data-lucide="${icon}" class="w-4 h-4 shrink-0"></i>
                    <span class="text-sm font-medium truncate flex-1">${escapeHtml(label)}</span>
                    <span class="text-xs bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded-full">${count}</span>
                </button>
            `;
        });

        container.innerHTML = html;
        lucide.createIcons({ nodes: [container] });
    }

    async function selectGroup(groupKey) {
        currentGroup = groupKey;
        document.getElementById('groupTitle').textContent = groupLabels[groupKey] || groupKey;
        const addBtn = document.getElementById('addBtn');
        addBtn.style.display = 'flex';

        await loadGroups();
        await loadValues(groupKey);
    }

    async function loadValues(groupKey) {
        const container = document.getElementById('valuesContainer');
        container.innerHTML = '<div class="text-center py-6"><i data-lucide="loader-2" class="w-5 h-5 animate-spin mx-auto text-slate-400"></i></div>';
        lucide.createIcons({ nodes: [container] });

        try {
            const response = await apiCall(`/lookups/${groupKey}?all=1`, 'GET');
            if (response && response.status === 'success') {
                currentValues = response.data;
                renderValues(currentValues);
            }
        } catch (e) {
            container.innerHTML = '<p class="text-sm text-rose-500 text-center py-6">Veriler yüklenemedi.</p>';
        }
    }

    function renderValues(values) {
        const container = document.getElementById('valuesContainer');
        if (values.length === 0) {
            container.innerHTML = '<p class="text-sm text-slate-400 text-center py-8">Bu grupta henüz tanım yok.</p>';
            return;
        }

        let html = `
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-200 text-left">
                            <th class="pb-2 font-medium text-slate-500 text-xs uppercase tracking-wider w-12">Sıra</th>
                            <th class="pb-2 font-medium text-slate-500 text-xs uppercase tracking-wider">Değer</th>
                            <th class="pb-2 font-medium text-slate-500 text-xs uppercase tracking-wider">Etiket</th>
                            <th class="pb-2 font-medium text-slate-500 text-xs uppercase tracking-wider text-center w-20">Durum</th>
                            <th class="pb-2 font-medium text-slate-500 text-xs uppercase tracking-wider text-center w-20">Tür</th>
                            <th class="pb-2 font-medium text-slate-500 text-xs uppercase tracking-wider text-right w-24">İşlem</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
        `;

        values.forEach(item => {
            const isSystem = parseInt(item.is_system) === 1;
            const isActive = parseInt(item.is_active) === 1;

            const statusBadge = isActive
                ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200">Aktif</span>'
                : '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500 border border-slate-200">Pasif</span>';

            const typeBadge = isSystem
                ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">Sistem</span>'
                : '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-50 text-slate-500 border border-slate-200">Özel</span>';

            html += `
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="py-2.5 text-slate-500">${item.sort_order}</td>
                    <td class="py-2.5 font-mono text-xs text-slate-600">${escapeHtml(item.value)}</td>
                    <td class="py-2.5 text-slate-700 font-medium">${escapeHtml(item.label)}</td>
                    <td class="py-2.5 text-center">${statusBadge}</td>
                    <td class="py-2.5 text-center">${typeBadge}</td>
                    <td class="py-2.5 text-right">
                        <div class="flex items-center justify-end gap-1">
                            <button onclick="editLookup(${item.id})" class="p-1.5 text-slate-400 hover:text-gold-custom hover:bg-gold-custom/10 rounded transition-colors" title="Düzenle">
                                <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                            </button>
                            ${!isSystem ? `
                            <button onclick="deleteLookup(${item.id})" class="p-1.5 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded transition-colors" title="Sil">
                                <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                            </button>` : ''}
                        </div>
                    </td>
                </tr>
            `;
        });

        html += '</tbody></table></div>';
        container.innerHTML = html;
        lucide.createIcons({ nodes: [container] });
    }

    function openAddModal() {
        if (!currentGroup) return;
        document.getElementById('lookupEditId').value = '';
        document.getElementById('lookupValue').value = '';
        document.getElementById('lookupLabel').value = '';
        document.getElementById('lookupSortOrder').value = '0';
        document.getElementById('lookupIsActive').value = '1';
        document.getElementById('lookupValue').disabled = false;
        document.getElementById('lookupValueField').classList.remove('opacity-50');
        document.getElementById('lookupModalTitle').innerHTML = '<i data-lucide="list-ordered" class="w-5 h-5 text-gold-custom"></i> Yeni Değer Ekle';
        document.getElementById('lookupSaveText').textContent = 'Kaydet';
        document.getElementById('lookupModalAlert').className = 'hidden';
        openModal('lookupModal', 'lookupModalContent');
    }

    function editLookup(id) {
        const item = currentValues.find(v => v.id == id);
        if (!item) return;

        document.getElementById('lookupEditId').value = item.id;
        document.getElementById('lookupValue').value = item.value;
        document.getElementById('lookupLabel').value = item.label;
        document.getElementById('lookupSortOrder').value = item.sort_order;
        document.getElementById('lookupIsActive').value = item.is_active;

        const isSystem = parseInt(item.is_system) === 1;
        document.getElementById('lookupValue').disabled = isSystem;
        document.getElementById('lookupValueField').classList.toggle('opacity-50', isSystem);

        document.getElementById('lookupModalTitle').innerHTML = '<i data-lucide="edit" class="w-5 h-5 text-gold-custom"></i> Değer Düzenle';
        document.getElementById('lookupSaveText').textContent = 'Güncelle';
        document.getElementById('lookupModalAlert').className = 'hidden';
        openModal('lookupModal', 'lookupModalContent');
    }

    function closeLookupModal() {
        closeModal('lookupModal', 'lookupModalContent');
    }

    async function saveLookup() {
        const editId = document.getElementById('lookupEditId').value;
        const value = document.getElementById('lookupValue').value.trim();
        const label = document.getElementById('lookupLabel').value.trim();
        const sortOrder = parseInt(document.getElementById('lookupSortOrder').value) || 0;
        const isActive = document.getElementById('lookupIsActive').value;

        if (!value || !label) {
            showLookupAlert('Değer ve Etiket alanları zorunludur.');
            return;
        }

        try {
            let response;
            if (editId) {
                response = await apiCall(`/lookups/${editId}`, 'PUT', {
                    value, label, sort_order: sortOrder, is_active: parseInt(isActive)
                });
            } else {
                response = await apiCall('/lookups', 'POST', {
                    group_key: currentGroup, value, label, sort_order: sortOrder, is_active: parseInt(isActive)
                });
            }

            if (response && response.status === 'success') {
                closeLookupModal();
                showToast(editId ? 'Tanım güncellendi.' : 'Tanım eklendi.', 'success');
                clearLookupCache(currentGroup);
                await loadGroups();
                await loadValues(currentGroup);
            } else {
                showLookupAlert(response?.message || 'Bir hata oluştu.');
            }
        } catch (e) {
            showLookupAlert('Sunucu ile iletişim kurulamadı.');
        }
    }

    async function deleteLookup(id) {
        const confirmed = await showConfirm('Tanımı Sil', 'Bu tanım değerini silmek istediğinize emin misiniz?', 'Evet, Sil');
        if (!confirmed) return;

        try {
            const response = await apiCall(`/lookups/${id}`, 'DELETE');
            if (response && response.status === 'success') {
                showToast('Tanım silindi.', 'success');
                clearLookupCache(currentGroup);
                await loadGroups();
                await loadValues(currentGroup);
            } else {
                showToast(response?.message || 'Silinemedi.', 'error');
            }
        } catch (e) {
            showToast('Sunucu ile iletişim kurulamadı.', 'error');
        }
    }

    function showLookupAlert(msg) {
        const el = document.getElementById('lookupModalAlert');
        el.textContent = msg;
        el.className = 'mb-0 p-3 rounded-md text-sm font-medium bg-rose-50 text-rose-700 border border-rose-200';
    }
</script>
{% endblock %}
